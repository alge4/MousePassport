<Window x:Class="MousePassport.App.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MousePassport Setup"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Window.Background}"
        FontFamily="{StaticResource Font.Ui}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <DockPanel Margin="20,18,20,18">
        <!-- Hero / intro glass panel -->
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,14"
                CornerRadius="14"
                BorderBrush="{StaticResource Brush.Border.Glass}"
                BorderThickness="1"
                Background="{StaticResource Brush.Glass.Card}"
                Effect="{StaticResource Effect.Card.Shadow}">
            <Border CornerRadius="14" Padding="20,16,20,16">
                <StackPanel Orientation="Vertical">
                    <TextBlock Style="{StaticResource Text.Headline}"
                               Text="Configure pass-through edges" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource Text.Body}"
                               Text="Monitor positions come from Windows Display Settings (read-only). Drag the handles on shared edges to choose where the cursor may cross between displays." />
                    <TextBlock x:Name="StatusText"
                               Margin="0,12,0,0"
                               Style="{StaticResource Text.Body}"
                               Foreground="{StaticResource Brush.Text.Success}"
                               Text="Detecting monitor edges..." />
                </StackPanel>
            </Border>
        </Border>

        <!-- Bottom toolbar -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,14,0,0"
                CornerRadius="12"
                BorderBrush="{StaticResource Brush.Border.Glass}"
                BorderThickness="1"
                Background="{StaticResource Brush.Glass.Toolbar}">
            <DockPanel Margin="14,12,14,12">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox x:Name="BoundaryHandleModeCheckBox"
                              Style="{StaticResource Glass.CheckBox}"
                              IsChecked="True"
                              Content="Single boundary handle"
                              Checked="DebugOverlayCheckBox_OnCheckedChanged"
                              Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
                    <CheckBox x:Name="DesktopLivePreviewCheckBox"
                              Style="{StaticResource Glass.CheckBox}"
                              IsChecked="True"
                              Content="Live desktop preview"
                              ToolTip="Shows pass-through on real monitor seams while you drag. Click-through overlay."
                              Checked="DesktopLivePreviewCheckBox_OnCheckedChanged"
                              Unchecked="DesktopLivePreviewCheckBox_OnCheckedChanged" />
                    <CheckBox x:Name="DebugOverlayCheckBox"
                              Style="{StaticResource Glass.CheckBox}"
                              IsChecked="True"
                              Content="Debug overlay"
                              Checked="DebugOverlayCheckBox_OnCheckedChanged"
                              Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
                    <CheckBox x:Name="LegacyHookModeCheckBox"
                              Style="{StaticResource Glass.CheckBox}"
                              Margin="0,0,0,0"
                              IsChecked="False"
                              Content="Deprecated Hook mode"
                              ToolTip="Legacy fallback. ClipCursor is recommended."
                              Checked="DebugOverlayCheckBox_OnCheckedChanged"
                              Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
                    <CheckBox x:Name="SuspendFullscreenCheckBox"
                              Style="{StaticResource Glass.CheckBox}"
                              Margin="16,0,0,0"
                              IsChecked="True"
                              Content="Pause when another app is fullscreen"
                              ToolTip="Stops cursor enforcement while a different fullscreen application is in the foreground so mouse capture works normally."
                              Checked="DebugOverlayCheckBox_OnCheckedChanged"
                              Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button x:Name="ResetButton"
                            Style="{StaticResource Glass.Button.Secondary}"
                            Width="132"
                            Margin="0,0,8,0"
                            Content="Reset full edges"
                            Click="ResetButton_OnClick" />
                    <Button x:Name="CancelButton"
                            Style="{StaticResource Glass.Button.Secondary}"
                            Width="100"
                            Margin="0,0,8,0"
                            Content="Cancel"
                            Click="CancelButton_OnClick" />
                    <Button x:Name="SaveButton"
                            Style="{StaticResource Glass.Button.Primary}"
                            Width="100"
                            IsDefault="True"
                            Content="Save"
                            Click="SaveButton_OnClick" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    CornerRadius="14"
                    BorderBrush="{StaticResource Brush.Border.Glass}"
                    BorderThickness="1"
                    Background="{StaticResource Brush.Glass.Card}"
                    Effect="{StaticResource Effect.Card.Shadow}">
                <Border CornerRadius="14"
                        Background="{StaticResource Brush.Canvas.Back}"
                        Margin="1"
                        ClipToBounds="True">
                    <Border CornerRadius="13" ClipToBounds="True">
                        <Canvas x:Name="LayoutCanvas"
                                Background="Transparent" />
                    </Border>
                </Border>
            </Border>

            <Border Grid.Column="1"
                    CornerRadius="14"
                    BorderBrush="{StaticResource Brush.Border.Glass}"
                    BorderThickness="1"
                    Background="{StaticResource Brush.Glass.Card}"
                    Effect="{StaticResource Effect.Card.Shadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Style="{StaticResource Text.SectionTitle}"
                               Margin="16,14,16,8"
                               Text="Layout diagnostics" />
                    <Border Margin="12,0,12,12"
                            CornerRadius="10"
                            BorderBrush="{StaticResource Brush.Border.Hairline}"
                            BorderThickness="1"
                            Background="#59FFFFFF"
                            ClipToBounds="True">
                        <TextBox x:Name="DebugText"
                                 Margin="10,8"
                                 FontFamily="{StaticResource Font.Mono}"
                                 FontSize="12"
                                 Foreground="{StaticResource Brush.Text.Primary}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" />
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
