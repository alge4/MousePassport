<Window x:Class="MousePassport.App.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MousePassport Setup"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Background="#FF121212"
                    Orientation="Vertical">
            <TextBlock Foreground="White"
                       FontSize="14"
                       Margin="16,12,16,6"
                       TextWrapping="Wrap"
                       Text="Monitor positions come from Windows Display Settings (read-only here). Drag circular handles on highlighted shared edges to set pass-through regions." />
            <TextBlock x:Name="StatusText"
                       Foreground="#FFD6F5D6"
                       FontSize="12"
                       Margin="16,0,16,12"
                       TextWrapping="Wrap"
                       Text="Detecting monitor edges..." />
        </StackPanel>

        <DockPanel DockPanel.Dock="Bottom"
                   Margin="12">
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <CheckBox x:Name="BoundaryHandleModeCheckBox"
                          IsChecked="True"
                          Margin="0,0,16,0"
                          Content="Single boundary handle mode"
                          Checked="DebugOverlayCheckBox_OnCheckedChanged"
                          Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
                <CheckBox x:Name="DebugOverlayCheckBox"
                          IsChecked="True"
                          Margin="0,0,16,0"
                          Content="Debug overlay"
                          Checked="DebugOverlayCheckBox_OnCheckedChanged"
                          Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
                <CheckBox x:Name="LegacyHookModeCheckBox"
                          IsChecked="False"
                          Content="Use deprecated Hook mode"
                          ToolTip="Legacy fallback mode. May feel less stable and can flicker more than ClipCursor mode."
                          Checked="DebugOverlayCheckBox_OnCheckedChanged"
                          Unchecked="DebugOverlayCheckBox_OnCheckedChanged" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
            <Button x:Name="ResetButton"
                    Width="130"
                    Margin="0,0,8,0"
                    Padding="8,4"
                    Content="Reset Full Edges"
                    Click="ResetButton_OnClick" />
            <Button x:Name="CancelButton"
                    Width="100"
                    Margin="0,0,8,0"
                    Padding="8,4"
                    Content="Cancel"
                    Click="CancelButton_OnClick" />
            <Button x:Name="SaveButton"
                    Width="100"
                    Padding="8,4"
                    IsDefault="True"
                    Content="Save"
                    Click="SaveButton_OnClick" />
            </StackPanel>
        </DockPanel>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#FF303030"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#FFF7F7F7"
                    Margin="0,0,8,0">
                <Canvas x:Name="LayoutCanvas"
                        Background="Transparent" />
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="#FF303030"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#FFFBFBFB">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="10,10,10,6"
                               FontWeight="SemiBold"
                               Text="Layout Diagnostics" />
                    <TextBox x:Name="DebugText"
                             Margin="10,0,10,10"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
