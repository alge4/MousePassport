<Application x:Class="MousePassport.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MousePassport.App">
    <Application.Resources>
        <FontFamily x:Key="Font.Ui">Segoe UI Variable, Segoe UI</FontFamily>
        <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas</FontFamily>

        <!-- Surfaces -->
        <Color x:Key="Color.Window.Top">#FFE8EBF2</Color>
        <Color x:Key="Color.Window.Bottom">#FFF1F3F8</Color>
        <Color x:Key="Color.Glass.Fill">#CCFFFFFF</Color>
        <Color x:Key="Color.Glass.Fill.Strong">#E8FFFFFF</Color>
        <Color x:Key="Color.Glass.Stroke">#28000000</Color>
        <Color x:Key="Color.Glass.Toolbar">#B3F5F6FA</Color>
        <Color x:Key="Color.Canvas.Back">#F5F7FB</Color>

        <!-- Text -->
        <Color x:Key="Color.Text.Primary">#FF1A1A1C</Color>
        <Color x:Key="Color.Text.Secondary">#FF5C5C63</Color>
        <Color x:Key="Color.Text.Success">#FF0F6B3A</Color>
        <Color x:Key="Color.Text.Warning">#FF9D5D00</Color>
        <Color x:Key="Color.Text.Danger">#FFC4312A</Color>

        <!-- Accent (Windows 11–style) -->
        <Color x:Key="Color.Accent">#FF0067C0</Color>
        <Color x:Key="Color.Accent.Hover">#FF0078D4</Color>
        <Color x:Key="Color.Accent.Pressed">#FF005A9E</Color>

        <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
        <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
        <SolidColorBrush x:Key="Brush.Text.Success" Color="{StaticResource Color.Text.Success}" />
        <SolidColorBrush x:Key="Brush.Text.Warning" Color="{StaticResource Color.Text.Warning}" />
        <SolidColorBrush x:Key="Brush.Text.Danger" Color="{StaticResource Color.Text.Danger}" />
        <SolidColorBrush x:Key="Brush.Border.Glass" Color="{StaticResource Color.Glass.Stroke}" />
        <SolidColorBrush x:Key="Brush.Border.Hairline" Color="#14000000" />

        <LinearGradientBrush x:Key="Brush.Window.Background" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource Color.Window.Top}" Offset="0" />
            <GradientStop Color="{StaticResource Color.Window.Bottom}" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="Brush.Glass.Card" Color="{StaticResource Color.Glass.Fill}" />
        <SolidColorBrush x:Key="Brush.Glass.Card.Strong" Color="{StaticResource Color.Glass.Fill.Strong}" />
        <SolidColorBrush x:Key="Brush.Glass.Toolbar" Color="{StaticResource Color.Glass.Toolbar}" />
        <SolidColorBrush x:Key="Brush.Canvas.Back" Color="{StaticResource Color.Canvas.Back}" />

        <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
        <SolidColorBrush x:Key="Brush.Accent.Hover" Color="{StaticResource Color.Accent.Hover}" />
        <SolidColorBrush x:Key="Brush.Accent.Pressed" Color="{StaticResource Color.Accent.Pressed}" />
        <SolidColorBrush x:Key="Brush.OnAccent" Color="White" />

        <!-- Soft card shadow (diffused, minimal depth) -->
        <DropShadowEffect x:Key="Effect.Card.Shadow"
                          BlurRadius="28"
                          ShadowDepth="0"
                          Opacity="0.12"
                          Color="#FF000000" />

        <Style x:Key="Text.Headline" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="22" />
        </Style>

        <Style x:Key="Text.Body" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="19" />
        </Style>

        <Style x:Key="Text.SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        </Style>

        <Style x:Key="Glass.CheckBox" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,20,0" />
        </Style>

        <Style x:Key="Glass.Button.Secondary" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
            <Setter Property="Background" Value="{StaticResource Brush.Glass.Card.Strong}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Glass}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E2FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Glass.Button.Primary" TargetType="Button" BasedOn="{StaticResource Glass.Button.Secondary}">
            <Setter Property="Foreground" Value="{StaticResource Brush.OnAccent}" />
            <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Accent.Hover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.Accent.Hover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Accent.Pressed}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.Accent.Pressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
